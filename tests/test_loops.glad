PRINTLN "--- Loop Tester ---"

PRINTLN "Test 1: Simple countdown"
LET i = 5
WHILE i > 0
  PRINTLN "i = " + i
  i--
ENDWHILE
PRINTLN "Loop 1 finished."

PRINTLN "--- Test 2: CONTINUE (print even numbers) ---"
LET i = 10
WHILE i > 0
  i--
  # If the number is odd, skip the PRINTLN
  IF (i - (INT(i / 2) * 2)) != 0 THEN
    CONTINUE
  ENDIF
  PRINTLN "Even number: " + i
ENDWHILE
PRINTLN "Loop 2 finished."

PRINTLN "--- Test 3: BREAK (find first multiple of 7) ---"
LET i = 100
LET found = NULL
WHILE i > 0
  IF (i - (INT(i / 7) * 7)) == 0 THEN
    found = i
    BREAK # Exit the loop
  ENDIF
  i--
ENDWHILE
PRINTLN "Loop 3 finished."
PRINTLN "Found first multiple of 7 (under 100): " + found

PRINTLN "--- Zero-Iteration WHILE Tests ---"

LET counter = 0

PRINTLN "Test 1: WHILE FALSE"
WHILE FALSE
    PRINTLN "This should NOT print"
    counter = counter + 1
ENDWHILE
PRINTLN "Counter after FALSE loop: " + STR(counter) + " (expected: 0)"

PRINTLN "Test 2: WHILE 0"
WHILE 0
    PRINTLN "This should NOT print"
    counter = counter + 1
ENDWHILE
PRINTLN "Counter after 0 loop: " + STR(counter) + " (expected: 0)"

PRINTLN "Test 3: WHILE condition initially false (a = 10, b = 5)"
LET a = 10
LET b = 5
WHILE a < b
    PRINTLN "This should NOT print"
    a = a - 1
ENDWHILE
PRINTLN "Loop skipped, a remains: " + STR(a) + " (expected: 10)"

PRINTLN "All zero-iteration tests passed."