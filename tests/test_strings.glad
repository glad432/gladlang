PRINTLN "--- Escape Character Tester ---"

LET newline = "Hello\nWorld"
PRINTLN newline

LET tabbed = "Column 1\tColumn 2"
PRINTLN tabbed

LET quoted = "She said, \"This language is cool!\""
PRINTLN quoted

LET path = "C:\\Users\\Glad\\My Lang"
PRINTLN path

LET combined = "Line 1\n\tLine 2 (indented)\nLine 3"
PRINTLN combined

PRINTLN "\n-- String Iteration --"
LET text = "Hi"
FOR char IN text
    PRINTLN "Char: " + char
ENDFOR
# Expected: H, i

PRINTLN "\n-- String Comprehension --"
LET chars = [c FOR c IN "abc"]
PRINTLN "Chars: " + STR(chars)
# Expected: ['a', 'b', 'c']

PRINTLN "\n-- String Repetition --"
LET base = "5"
LET repeated = base * 10
PRINTLN "Repeating '5' ten times: " + repeated
# Expected: 5555555555

PRINTLN "--- Unicode / Tamil & Kannada Strings ---"

LET tamil_str = "வணக்கம்"
PRINTLN "Tamil string: " + tamil_str
PRINTLN "Length: " + STR(LEN(tamil_str))

LET kannada_str = "ನಮಸ್ಕಾರ"
PRINTLN "Kannada string: " + kannada_str
PRINTLN "Length: " + STR(LEN(kannada_str))

LET mixed = "Tamil: " + tamil_str + ", Kannada: " + kannada_str
PRINTLN "Mixed: " + mixed
PRINTLN "Length: " + STR(LEN(mixed))

PRINTLN "Iteration over Tamil string:"
FOR ch IN tamil_str
    PRINT "[" + ch + "]"
ENDFOR
PRINTLN ""

LET combined = tamil_str + " & " + kannada_str
PRINTLN "Concatenated: " + combined

LET chars = [c FOR c IN "abc " + tamil_str]
PRINTLN "Comprehension chars: " + STR(chars)

PRINTLN "All Unicode (Tamil/Kannada) tests passed."