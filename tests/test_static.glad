PRINTLN "=== STARTING COMPREHENSIVE STATIC FEATURE TEST ==="

# ---------------------------------------------------------
# 1. DEFINE CLASSES
# ---------------------------------------------------------

CLASS Config
    # Static Constants
    STATIC FINAL MAX_USERS = 100
    STATIC FINAL APP_NAME = "GladApp"
    
    # Static Private (Should not be seen outside)
    STATIC PRIVATE LET secret_key = 12345

    # Static Method to reveal secret (tests internal access)
    STATIC PUBLIC DEF get_secret()
        RETURN Config.secret_key
    ENDDEF
ENDCLASS

CLASS BaseService
    # Protected Static: Visible to Subclasses
    STATIC PROTECTED LET service_name = "Base"
    
    STATIC PUBLIC DEF get_base_name()
        RETURN BaseService.service_name
    ENDDEF
ENDCLASS

CLASS UserService INHERITS BaseService
    # Static Variable (Mutable)
    STATIC PUBLIC LET user_count = 0

    # Static Constructor Logic (Manual)
    STATIC PUBLIC DEF init_static()
        UserService.user_count = 10
    ENDDEF

    # Static Method modifying Static Field
    STATIC PUBLIC DEF add_user()
        UserService.user_count = UserService.user_count + 1
        RETURN UserService.user_count
    ENDDEF

    # Test Accessing Parent Static (Protected)
    STATIC PUBLIC DEF get_parent_name()
        # Should be able to access 'service_name' from BaseService
        RETURN BaseService.service_name
    ENDDEF
    
    # Instance method accessing Static
    PUBLIC DEF instance_info()
        RETURN "Instance seeing static: " + UserService.user_count
    ENDDEF
ENDCLASS

# ---------------------------------------------------------
# 2. TEST EXECUTION
# ---------------------------------------------------------

PRINTLN "\n[TEST 1] Static Constants (FINAL)"
PRINTLN "App Name: " + Config.APP_NAME
PRINTLN "Max Users: " + Config.MAX_USERS

PRINTLN "\n[TEST 2] Static Variables & Modification"
UserService.init_static()
PRINTLN "Initial Count: " + UserService.user_count
PRINTLN "Adding user... New Count: " + UserService.add_user()
PRINTLN "Adding user... New Count: " + UserService.add_user()

PRINTLN "\n[TEST 3] Inheritance & Protected Access"
PRINTLN "Direct Parent Access: " + BaseService.get_base_name()
PRINTLN "Child Accessing Parent Static: " + UserService.get_parent_name()

PRINTLN "\n[TEST 4] Instance Accessing Static Members (Java Style)"
LET u = NEW UserService()
# Calling static method via instance
PRINTLN "Via Instance (Method): " + u.add_user() 
# Accessing static field via instance (if supported by your logic, otherwise via getter)
PRINTLN "Via Instance (Internal Logic): " + u.instance_info()

# ---------------------------------------------------------
# 3. NEGATIVE TESTS (ERROR HANDLING)
# ---------------------------------------------------------
PRINTLN "\n[TEST 5] Security & Error Handling"

# A. Try to modify a FINAL static field
PRINTLN "-> Attempting to modify STATIC FINAL..."
TRY
    Config.MAX_USERS = 200
    PRINTLN "FAIL: Should not have allowed modification!"
CATCH error
    PRINTLN "PASS: Caught expected error: " + error
ENDTRY

# B. Try to access PRIVATE static field from outside
PRINTLN "-> Attempting to access STATIC PRIVATE from outside..."
TRY
    PRINTLN Config.secret_key
    PRINTLN "FAIL: Should not see private field!"
CATCH error
    PRINTLN "PASS: Caught expected error: " + error
ENDTRY

# C. Verify Private is accessible internally
PRINTLN "-> Accessing PRIVATE via Public Static Method..."
TRY
    PRINTLN "Secret revealed: " + Config.get_secret()
    PRINTLN "PASS: Internal access allowed."
CATCH error
    PRINTLN "FAIL: Internal access blocked: " + error
ENDTRY

# D. Try to call Instance Method statically
PRINTLN "-> Attempting to call Instance Method on Class..."
TRY
    UserService.instance_info()
    PRINTLN "FAIL: Should not allow instance call on Class!"
CATCH error
    PRINTLN "PASS: Caught expected error: " + error
ENDTRY

PRINTLN "--- STATIC FINAL ENUM in Class ---"

CLASS AppConfig
    PUBLIC ENUM LogLevel
        DEBUG
        INFO
        WARN
        ERROR
    ENDENUM

    PUBLIC STATIC FINAL MAX_RETRIES = 5
    PUBLIC STATIC FINAL DEFAULT_LEVEL = LogLevel.INFO
ENDCLASS

PRINTLN "LogLevel.DEBUG = " + STR(AppConfig.LogLevel.DEBUG) + " (expected: 0)"
PRINTLN "LogLevel.INFO = " + STR(AppConfig.LogLevel.INFO) + " (expected: 1)"
PRINTLN "LogLevel.WARN = " + STR(AppConfig.LogLevel.WARN) + " (expected: 2)"
PRINTLN "LogLevel.ERROR = " + STR(AppConfig.LogLevel.ERROR) + " (expected: 3)"
PRINTLN "MAX_RETRIES = " + STR(AppConfig.MAX_RETRIES) + " (expected: 5)"
PRINTLN "DEFAULT_LEVEL = " + STR(AppConfig.DEFAULT_LEVEL) + " (expected: 1)"

PRINTLN ""
PRINTLN "Attempting to modify STATIC FINAL (should fail)..."
TRY
    AppConfig.MAX_RETRIES = 10
    PRINTLN "FAIL: Should not allow modification"
CATCH e
    PRINTLN "SUCCESS: Caught error -> " + e
ENDTRY

TRY
    AppConfig.LogLevel.DEBUG = 99
    PRINTLN "FAIL: Should not modify enum case"
CATCH e
    PRINTLN "SUCCESS: Caught error -> " + e
ENDTRY

PRINTLN "-> Attempting to use THIS inside a STATIC method..."
CLASS StaticThisTester
    STATIC PUBLIC DEF bad_method()
        RETURN THIS.some_field
    ENDDEF
ENDCLASS
TRY
    StaticThisTester.bad_method()
    PRINTLN "FAIL: Should have rejected THIS in static method"
CATCH e
    PRINTLN "SUCCESS: Caught expected error -> " + e
ENDTRY

PRINTLN "-> Attempting to use SUPER inside a STATIC method..."
CLASS SuperStaticParent
    STATIC DEF parent_method()
        RETURN "parent"
    ENDDEF
ENDCLASS
CLASS SuperStaticChild INHERITS SuperStaticParent
    STATIC PUBLIC DEF child_method()
        RETURN SUPER.parent_method()
    ENDDEF
ENDCLASS
TRY
    SuperStaticChild.child_method()
    PRINTLN "FAIL: Should have rejected SUPER in static method"
CATCH e
    PRINTLN "SUCCESS: Caught expected error -> " + e
ENDTRY

PRINTLN "\n=== ALL TESTS COMPLETED ==="