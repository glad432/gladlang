PRINTLN "=============================================="
PRINTLN " GLADLANG TRACEBACK — FULL TEST SUITE"
PRINTLN "=============================================="
PRINTLN ""

LET pass_count = 0
LET fail_count = 0

DEF pass(name)
  PRINTLN "[PASS] " + name
  pass_count = pass_count + 1
ENDDEF

DEF fail(name, reason)
  PRINTLN "[FAIL] " + name + " -> " + reason
  fail_count = fail_count + 1
ENDDEF

PRINTLN "--- Test 1: THROW position ---"

TRY
  THROW "error from throw"
  PRINTLN "UNREACHABLE"
CATCH e
  IF e == "error from throw" THEN
    pass("Test 1a: THROW fires with correct message")
  ELSE
    fail("Test 1a", "wrong message: " + e)
  ENDIF
ENDTRY

DEF bug1_thrower()
  THROW "thrown inside function"
  PRINTLN "UNREACHABLE"
ENDDEF

TRY
  bug1_thrower()
CATCH e
  IF e == "thrown inside function" THEN
    pass("Test 1b: THROW inside function fires correctly")
  ELSE
    fail("Test 1b", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 2: TRY position ---"

TRY
  TRY
    LET _x = 1 / 0
  CATCH e
    THROW "rethrown: " + e
  ENDTRY
CATCH e
  IF e == "rethrown: Division by zero" THEN
    pass("Test 2: error propagates correctly through TRY/CATCH/RETHROW chain")
  ELSE
    fail("Test 2", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 3a: BoundMethod call-site position ---"

CLASS _B3
  DEF _B3()
    THIS.v = 0
  ENDDEF
  DEF crash_me()
    LET _z = 1 / 0
  ENDDEF
ENDCLASS

TRY
  LET _b3 = NEW _B3()
  _b3.crash_me()
CATCH e
  IF e == "Division by zero" THEN
    pass("Test 3a: method error fires with correct message")
  ELSE
    fail("Test 3a", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 3b: BoundMethod recursion limit context ---"

CLASS _B3b
  DEF _B3b()
    THIS.n = 0
  ENDDEF
  DEF loop()
    THIS.n = THIS.n + 1
    RETURN THIS.loop()
  ENDDEF
ENDCLASS

TRY
  LET _b3b = NEW _B3b()
  _b3b.loop()
CATCH e
  IF e == "Recursion limit exceeded" OR e == "Expression too complex (maximum recursion depth exceeded)" OR e == "Total recursion calls exceeded limit (10000)" THEN
    pass("Test 3b: method recursion limit fires (Python or GladLang limit)")
  ELSE
    fail("Test 3b", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 3c: Overloaded method wrong-arity error ---"

CLASS _B3c
  DEF do_work(x)
    RETURN x * 2
  ENDDEF
  DEF do_work(x, y)
    RETURN x + y
  ENDDEF
ENDCLASS

TRY
  LET _b3c = NEW _B3c()
  _b3c.do_work()
CATCH e
  IF e == "No variant of function 'do_work' found that accepts 1 arguments" THEN
    pass("Test 3c: overloaded method wrong-arity fires with non-empty message")
  ELSE
    fail("Test 3c", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 4: BuiltInFunction context ---"

TRY
  LEN(1, 2, 3)
CATCH e
  IF e == "Incorrect argument count for 'LEN'. Expected 1, got 3" THEN
    pass("Test 4a: LEN wrong-arity error has non-empty message")
  ELSE
    fail("Test 4a", "wrong message: " + e)
  ENDIF
ENDTRY

TRY
  INT("not a number at all xyz")
CATCH e
  IF e == "Cannot convert 'not a number at all xyz' to INT" THEN
    pass("Test 4b: INT conversion error has non-empty message")
  ELSE
    fail("Test 4b", "wrong message: " + e)
  ENDIF
ENDTRY

DEF _b4_caller(val)
  RETURN INT(val)
ENDDEF

LET _b4c_caught = FALSE
TRY
  _b4_caller("not a number xyz")
CATCH e
  _b4c_caught = TRUE
  IF e == "Cannot convert 'not a number xyz' to INT" THEN
    pass("Test 4c: BuiltIn error inside function has non-empty message")
  ELSE
    fail("Test 4c", "wrong message: " + e)
  ENDIF
ENDTRY

IF NOT _b4c_caught THEN
  fail("Test 4c", "no exception was raised - INT() succeeded unexpectedly")
ENDIF

PRINTLN ""

PRINTLN "--- Test 5: FunctionGroup call-site position ---"

DEF _b5_add(a, b)
  LET _r = a / b
  RETURN _r
ENDDEF

DEF _b5_add(a, b, c)
  RETURN a + b + c
ENDDEF

TRY
  _b5_add(10, 0)
CATCH e
  IF e == "Division by zero" THEN
    pass("Test 5a: overloaded function body error fires correctly")
  ELSE
    fail("Test 5a", "wrong message: " + e)
  ENDIF
ENDTRY

TRY
  _b5_add(1)
CATCH e
  IF e == "No variant of function '_b5_add' found that accepts 1 arguments" THEN
    pass("Test 5b: overloaded function no-variant error has non-empty message")
  ELSE
    fail("Test 5b", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 6a: NEW constructor call-site position ---"

CLASS _B6
  DEF _B6()
    LET _x = 1 / 0
  ENDDEF
ENDCLASS

TRY
  LET _b6 = NEW _B6()
CATCH e
  IF e == "Division by zero" THEN
    pass("Test 6a: constructor error fires with correct message")
  ELSE
    fail("Test 6a", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 6b: No-constructor error position and context ---"

CLASS _B6b
ENDCLASS

TRY
  LET _b6b = NEW _B6b(1, 2, 3)
CATCH e
  IF e == "'_B6b' does not have a constructor that accepts arguments" THEN
    pass("Test 6b: no-constructor error has non-empty message")
  ELSE
    fail("Test 6b", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 7: SUPER() call-site position ---"

CLASS _B7Animal
  DEF _B7Animal()
    LET _x = 1 / 0
  ENDDEF
ENDCLASS

CLASS _B7Dog INHERITS _B7Animal
  DEF _B7Dog()
    SUPER()
  ENDDEF
ENDCLASS

TRY
  LET _b7 = NEW _B7Dog()
CATCH e
  IF e == "Division by zero" THEN
    pass("Test 7: SUPER() propagates constructor error correctly")
  ELSE
    fail("Test 7", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 8: Wrong-arity error shows intermediate call frames ---"

DEF _b8_inner(a, b)
  RETURN a + b
ENDDEF

DEF _b8_outer()
  _b8_inner(1)
ENDDEF

TRY
  _b8_outer()
CATCH e
  IF e == "Incorrect argument count for '_b8_inner'. Expected 2, got 1" THEN
    pass("Test 8: wrong-arity error from nested call has non-empty message")
  ELSE
    fail("Test 8", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 9: Recursion limit context (function) ---"

DEF _b9_inf(n)
  LET _tmp = _b9_inf(n + 1)
  RETURN _tmp
ENDDEF

TRY
  _b9_inf(0)
CATCH e
  IF e == "Recursion limit exceeded" OR e == "Expression too complex (maximum recursion depth exceeded)" THEN
    pass("Test 9: function recursion limit fires with correct message")
  ELSE
    fail("Test 9", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 10: No-member error uses calling context ---"

CLASS _B10
  DEF _B10()
    THIS.x = 0
  ENDDEF
ENDCLASS

DEF _b10_accessor()
  LET _o = NEW _B10()
  LET _v = _o.nonexistent_member
ENDDEF

TRY
  _b10_accessor()
CATCH e
  IF e == "Class '_B10' has no member 'nonexistent_member'" THEN
    pass("Test 10: no-member error has non-empty message")
  ELSE
    fail("Test 10", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 11: Class called without NEW uses calling context ---"

CLASS _B11
  DEF _B11()
    THIS.id = 1
  ENDDEF
ENDCLASS

DEF _b11_caller()
  LET _w = _B11()
ENDDEF

TRY
  _b11_caller()
CATCH e
  IF e == "Class '_B11' must be instantiated using 'NEW'" THEN
    pass("Test 11: must-use-NEW error has non-empty message")
  ELSE
    fail("Test 11", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 12: Instance illegal operation has traceback ---"

CLASS _B12
  DEF _B12(v)
    THIS.v = v
  ENDDEF
ENDCLASS

TRY
  LET _b12 = NEW _B12(5)
  LET _bad = _b12 + 10
CATCH e
  IF e == "Illegal operation" THEN
    pass("Test 12a: instance illegal op fires with correct message")
  ELSE
    fail("Test 12a", "wrong message: " + e)
  ENDIF
ENDTRY

CLASS _B12b
  DEF _B12b(v)
    THIS.v = v
  ENDDEF
  DEF clone()
    RETURN NEW _B12b(THIS.v)
  ENDDEF
ENDCLASS

TRY
  LET _b12b = NEW _B12b(3)
  LET _copy = _b12b.clone()
  LET _bad2 = _copy * "oops"
CATCH e
  IF e == "Illegal operation" THEN
    pass("Test 12b: instance-from-method illegal op fires with correct message")
  ELSE
    fail("Test 12b", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 13: Traceback null-pos guard (no Python crash) ---"

TRY
  LET _x = 1 / 0
CATCH e
  IF e == "Division by zero" THEN
    pass("Test 13a: division by zero traceback did not crash")
  ELSE
    fail("Test 13a", "wrong message: " + e)
  ENDIF
ENDTRY

TRY
  LEN(1, 2, 3)
CATCH e
  IF e == "Incorrect argument count for 'LEN'. Expected 1, got 3" THEN
    pass("Test 13b: built-in error traceback did not crash")
  ELSE
    fail("Test 13b", "wrong message: " + e)
  ENDIF
ENDTRY

TRY
  THROW "guard test"
CATCH e
  IF e == "guard test" THEN
    pass("Test 13c: throw error traceback did not crash")
  ELSE
    fail("Test 13c", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "--- Test 14: Collection access errors show access line ---"

LET _arr14 = [10, 20, 30]

TRY
  LET _bad = _arr14[99]
CATCH e
  IF e == "List index 99 out of bounds" THEN
    pass("Test 14a: list out-of-bounds read error fires with message")
  ELSE
    fail("Test 14a", "wrong message: " + e)
  ENDIF
ENDTRY

TRY
  LET _arr14[99] = 0
CATCH e
  IF e == "List index 99 out of bounds" THEN
    pass("Test 14b: list out-of-bounds write error fires with message")
  ELSE
    fail("Test 14b", "wrong message: " + e)
  ENDIF
ENDTRY

LET _dict14 = {"a": 1, "b": 2}

TRY
  LET _bad2 = _dict14["z"]
CATCH e
  IF e == "Key 'z' not found" THEN
    pass("Test 14c: dict key-not-found error fires with message")
  ELSE
    fail("Test 14c", "wrong message: " + e)
  ENDIF
ENDTRY

LET _str14 = "hi"

TRY
  LET _bad3 = _str14[99]
CATCH e
  IF e == "String index 99 out of bounds" THEN
    pass("Test 14d: string out-of-bounds error fires with message")
  ELSE
    fail("Test 14d", "wrong message: " + e)
  ENDIF
ENDTRY

PRINTLN ""

PRINTLN "=============================================="
PRINTLN " RESULTS"
PRINTLN "=============================================="
PRINTLN "PASSED: " + pass_count
PRINTLN "FAILED: " + fail_count
IF fail_count == 0 THEN
  PRINTLN "ALL TESTS PASSED"
ELSE
  PRINTLN "SOME TESTS FAILED — check output above"
ENDIF