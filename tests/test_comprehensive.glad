PRINTLN "--- 1. Advanced Math ---"
PRINTLN 2 ** 3        # Expected: 8
PRINTLN 10 // 3       # Expected: 3
PRINTLN 10 % 3        # Expected: 1
PRINTLN 2 + 3 * 4     # Expected: 14 (Precedence check)

PRINTLN ""
PRINTLN "--- 2. Comparisons ---"
PRINTLN 1 == 1        # Expected: 1 (True)
PRINTLN 1 != 2        # Expected: 1 (True)
PRINTLN 10 > 5        # Expected: 1 (True)
PRINTLN 5 <= 5        # Expected: 1 (True)

PRINTLN ""
PRINTLN "--- 3. Chained Comparisons ---"
LET age = 25
IF 18 <= age < 30 THEN
  PRINTLN "Age is between 18 and 30"
ENDIF
# Expected: "Age is between 18 and 30"

PRINTLN 1 < 2 < 3     # Expected: 1 (True)
PRINTLN 1 < 5 < 2     # Expected: 0 (False)

PRINTLN ""
PRINTLN "--- 4. Identity (IS operator) ---"
LET list_a = [1, 2, 3]
LET list_b = list_a
LET list_c = [1, 2, 3]

PRINTLN list_b IS list_a  # Expected: 1 (True - same object)
PRINTLN list_c IS list_a  # Expected: 0 (False - different objects)
PRINTLN list_c == list_a  # Expected: 1 (True - same values)

PRINTLN ""
PRINTLN "--- 5. Logic (AND, OR) ---"
# Standard Logic Check
IF 1 AND 1 THEN
  PRINTLN "Uppercase 'AND' works"
ENDIF

IF 0 OR 1 THEN
  PRINTLN "Uppercase 'OR' works"
ENDIF

PRINTLN ""
PRINTLN "--- 6. List Logic & Equality ---"
# This tests the fixes we just added (get_comparison_eq, anded_by)

LET l1 = [1, 2]
LET l2 = [1, 2]
LET l3 = [3, 4]

PRINTLN l1 == l2      # Expected: 1 (True)
PRINTLN l1 == l3      # Expected: 0 (False)
PRINTLN l1 != l3      # Expected: 1 (True)

# Testing Lists in Boolean contexts
IF [1] AND [2] THEN
  PRINTLN "Lists are Truthy"
ENDIF

# Complex combined logic
IF (l1 == l2) AND (l1 != l3) THEN
  PRINTLN "Complex List Logic Passed"
ENDIF
PRINTLN ""

PRINTLN "7. --- Very Large Number Overflow Tests ---"

PRINTLN "Testing 2^500 (should succeed)..."
LET huge = 2 ** 500
PRINTLN "2^500 has " + STR(LEN(STR(huge))) + " digits"

PRINTLN "Testing huge * huge (should succeed)..."
LET huge2 = huge * huge
PRINTLN "2^500 squared (i.e., 2^1000) has " + STR(LEN(STR(huge2))) + " digits"

PRINTLN "Testing exponent > 200000 (should fail, limit is 1000)..."
TRY
    LET overflow = 2 ** 200000
    PRINTLN "FAIL: Should have raised exponent limit error"
CATCH e
    PRINTLN "SUCCESS: Caught expected error -> " + e
ENDTRY

PRINTLN "Testing float overflow (exponent > 10000 blocked)..."
TRY
    LET float_big = 10.0 ** 50000
    PRINTLN "FAIL: Should have raised exponent limit error"
CATCH e
    PRINTLN "SUCCESS: Caught expected error -> " + e
ENDTRY
PRINTLN ""

PRINTLN "\nTesting integer bit-length limit (MAX_INT_BITS = 100000)..."
TRY
    LET huge_int = 2 ** 500
    FOR (LET i = 0; i < 8; i++)
        huge_int = huge_int * huge_int
    ENDFOR
    PRINTLN "Constructed a number with " + LEN(STR(huge_int)) + " digits"
    PRINTLN "Attempting to exceed bit-length limit..."
    LET too_big = huge_int * huge_int
    PRINTLN "FAIL: Should have exceeded integer size limit"
CATCH e
    PRINTLN "SUCCESS: Caught expected error -> " + e
ENDTRY

PRINTLN "--- DONE ---"